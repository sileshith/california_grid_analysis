      <column caption='High Priority Count' datatype='integer' name='[Calculation_2080618172174336]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [review_priority] = &quot;High Review Priority&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Scored Hour Count' datatype='integer' name='[Calculation_2080618174697473]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([stress_index]) THEN 1 ELSE 0 END' />
      </column>
      <column caption='Forecast Error MW' datatype='real' name='[Calculation_2080618465087490]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([demand_mw] - [demand_forecast_mw])' />
      </column>
      <column caption='Stress Rank' datatype='integer' name='[Calculation_2080618487427075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(AVG([stress_index]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Row Number' datatype='integer' name='[Calculation_2080618491236356]' role='measure' type='quantitative'>
