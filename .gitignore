# Python
__pycache__/
.ipynb_checkpoints/
*.pyc
*.pyo

# macOS
.DS_Store

# Data files — large files kept local only
*.csv
*.zip
*.xlsx
*.pbix
*.hyper
*.twbx

# Data directory contents — kept local only
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Output tables — kept local only
outputs/*.csv

# Notebook backups — large files kept local only
notebooks/*_with_outputs_backup.ipynb

# Tableau — temporary, recovery, and duplicate workbook files
tableau/*.twbr
tableau/.~*
tableau/*copy*.twb
tableau/CA_Grid_WB1_Executive_Dashboard.twb

# Reports — exclude temporary preview PNGs; keep PDF and generator
reports/previews/

# Environment
.env

# Database files (SQLite — kept local only)
*.db
*.sqlite
*.sqlite3

# Airflow
airflow_home/
logs/

# Pipeline temp files
/tmp/ca_grid_*.parquet

# pytest cache
.pytest_cache/
